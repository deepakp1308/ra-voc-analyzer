# R&A VOC Analyzer — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Slack Bot Token (requires scopes: channels:history, groups:history, users:read, chat:write, files:write)
SLACK_BOT_TOKEN=xoxb-your-token-here

# Anthropic API Key (Claude Sonnet 4.6 for classification)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Report delivery — Slack user ID to DM the weekly report to
REPORT_RECIPIENT_SLACK_ID=W8FL6URHQ

# Optional: Slack channel for failure alerts
ALERT_CHANNEL_ID=

# Cost budget per weekly run (USD)
WEEKLY_COST_BUDGET_USD=25.0

# Feature flags
ENABLE_SEMANTIC_DEDUP=false
